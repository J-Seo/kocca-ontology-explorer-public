# Turso (Tier B 표제어 DB) — 둘 다 필요
# 1) turso db create kocca-ontology
# 2) turso db show kocca-ontology --url
# 3) turso db tokens create kocca-ontology
TURSO_DATABASE_URL=libsql://<your-db>-<your-org>.turso.io
TURSO_AUTH_TOKEN=<your-token>

# 마이그레이션 시 로컬 sqlite 경로 (기본: src/data/lexicon/lexicon.sqlite)
# 기본 경로가 아니면 아래 주석을 풀어 절대경로를 지정하세요.
# LEXICON_SQLITE_PATH=/absolute/path/to/lexicon.sqlite
